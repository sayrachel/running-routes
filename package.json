{
  "name": "run-routes",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "web": "expo start --web",
    "test": "jest",
    "quality": "tsx lib/__tests__/route-quality-harness.ts",
    "quality:record": "tsx lib/__tests__/route-quality-harness.ts --record"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nern-fo-web)?|@expo(nent)?/.*)"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/lib/__tests__/route-quality-harness\\.ts$",
      "/lib/__tests__/simulate-routes\\.ts$",
      "/lib/__tests__/fixtures/"
    ]
  },
  "expo": {
    "install": {
      "exclude": [
        "@types/jest",
        "jest-expo",
        "react-native-worklets"
      ]
    }
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.2.3",
    "@expo-google-fonts/space-mono": "^0.2.3",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "babel-preset-expo": "^54.0.10",
    "expo": "^54.0.0",
    "expo-apple-authentication": "~8.0.8",
    "expo-asset": "~12.0.12",
    "expo-blur": "~15.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-store-review": "~9.0.9",
    "expo-task-manager": "~14.0.9",
    "firebase": "^12.9.0",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "^0.7.4"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@expo/ngrok": "^4.1.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.10",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
